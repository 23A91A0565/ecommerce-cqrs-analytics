# Write database
WRITE_DB_HOST=db
WRITE_DB_PORT=5432
WRITE_DB_NAME=write_db
WRITE_DB_USER=user
WRITE_DB_PASSWORD=password
DATABASE_URL=postgresql://user:password@db:5432/write_db

# Read database
READ_DB_HOST=read-db
READ_DB_PORT=5432
READ_DB_NAME=read_db
READ_DB_USER=user
READ_DB_PASSWORD=password
READ_DATABASE_URL=postgresql://user:password@read-db:5432/read_db

# Message broker
BROKER_HOST=broker
BROKER_PORT=5672
BROKER_URL=amqp://guest:guest@broker:5672/
BROKER_QUEUE=analytics.events

# Service ports
COMMAND_SERVICE_PORT=8080
QUERY_SERVICE_PORT=8081

# Outbox publisher tuning
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=100
